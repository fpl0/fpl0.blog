---
import { getCollection } from "astro:content";
import AppShell from "../../../../../layouts/AppShell.astro";

const papers = (await getCollection("vaultNotes"))
  .filter((n) => n.data.type === "paper")
  .sort((a, b) => {
    const ka = (a.data.authorYear ?? a.data.title ?? a.id) as string;
    const kb = (b.data.authorYear ?? b.data.title ?? b.id) as string;
    return ka.localeCompare(kb);
  });
---

<AppShell title="Papers — MSc Notes" description="Primary papers for the MSc in Cognitive Science." scrollable={true}>
  <div class="list-wrapper">
    <nav class="breadcrumb">
      <a href="/apps/msc-cogsci/">curriculum</a>
      <span>/</span>
      <a href="/apps/msc-cogsci/notes/">notes</a>
      <span>/</span>
      <span>papers</span>
    </nav>

    <header class="list-header">
      <h1>Papers <span class="count">{papers.length}</span></h1>
    </header>

    <ul class="item-list">
      {papers.map((note) => (
        <li>
          <a href={`/apps/msc-cogsci/notes/${note.id}`} class="item-link">
            <span class="item-key">{note.data.authorYear ?? note.data.title ?? note.id}</span>
            {note.data.title && note.data.authorYear && (
              <span class="item-title">{note.data.title}</span>
            )}
            {note.data.status && (
              <span class={`status-dot status-dot--${note.data.status}`} title={note.data.status} />
            )}
          </a>
        </li>
      ))}
    </ul>
  </div>
</AppShell>

<style>
  .list-wrapper {
    max-width: 72ch;
    margin: 0 auto;
    padding: var(--space-8) var(--space-6) var(--space-16);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
  }

  .breadcrumb a { color: var(--color-text-muted); text-decoration: none; cursor: pointer; }
  .breadcrumb a:hover { color: var(--color-text); text-decoration: underline; }

  .list-header {
    margin-bottom: var(--space-8);
  }

  .list-header h1 {
    font-size: var(--text-3xl, 1.875rem);
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
  }

  .count {
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }

  .item-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-1);
  }

  .item-link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: baseline;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md, 0.375rem);
    text-decoration: none;
    color: var(--color-text);
    font-size: var(--text-sm);
    transition: background 0.1s;
    cursor: pointer;
  }

  .item-link:hover {
    background: var(--color-surface-2, rgba(127,127,127,0.08));
  }

  .item-key {
    font-weight: 500;
    color: var(--color-text);
    white-space: nowrap;
  }

  .item-title {
    color: var(--color-text-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--color-border);
    align-self: center;
  }

  .status-dot--done { background: #22c55e; }
  .status-dot--in-progress { background: #f59e0b; }
  .status-dot--to-read { background: var(--color-border); }
</style>
