---
import { getCollection } from "astro:content";
import AppShell from "../../../../../layouts/AppShell.astro";

const artifacts = (await getCollection("vaultNotes"))
  .filter((n) => n.data.type === "artifact")
  .sort((a, b) => ((a.data.artifact ?? 99) as number) - ((b.data.artifact ?? 99) as number));
---

<AppShell title="Artifacts — MSc Notes" description="21 assessed artifacts for the MSc in Cognitive Science." scrollable={true}>
  <div class="list-wrapper">
    <nav class="breadcrumb">
      <a href="/apps/msc-cogsci/">curriculum</a>
      <span>/</span>
      <a href="/apps/msc-cogsci/notes/">notes</a>
      <span>/</span>
      <span>artifacts</span>
    </nav>

    <header class="list-header">
      <h1>Artifacts <span class="count">{artifacts.length}</span></h1>
    </header>

    <ul class="item-list">
      {artifacts.map((note) => {
        const n = note.data.artifact as number | undefined;
        const status = note.data.status as string | undefined;
        return (
          <li>
            <a href={`/apps/msc-cogsci/notes/${note.id}`} class="item-link">
              {n && <span class="item-num">A{String(n).padStart(2, "0")}</span>}
              <span class="item-title">{note.data.title ?? note.id}</span>
              {status && (
                <span class={`status-pill status-pill--${status}`}>{status}</span>
              )}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</AppShell>

<style>
  .list-wrapper {
    max-width: 72ch;
    margin: 0 auto;
    padding: var(--space-8) var(--space-6) var(--space-16);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
  }

  .breadcrumb a { color: var(--color-text-muted); text-decoration: none; cursor: pointer; }
  .breadcrumb a:hover { color: var(--color-text); text-decoration: underline; }

  .list-header {
    margin-bottom: var(--space-8);
  }

  .list-header h1 {
    font-size: var(--text-3xl, 1.875rem);
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
  }

  .count {
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }

  .item-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-1);
  }

  .item-link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md, 0.375rem);
    text-decoration: none;
    color: var(--color-text);
    font-size: var(--text-sm);
    transition: background 0.1s;
    cursor: pointer;
  }

  .item-link:hover {
    background: var(--color-surface-2, rgba(127,127,127,0.08));
  }

  .item-num {
    font-size: var(--text-xs);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    color: var(--color-text-muted);
    width: 3ch;
    flex-shrink: 0;
  }

  .item-title {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .status-pill {
    font-size: var(--text-xs);
    padding: 0.1em 0.5em;
    border-radius: 9999px;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .status-pill--shipped {
    color: var(--color-primary, #6366f1);
    border-color: var(--color-primary, #6366f1);
  }

  .status-pill--done {
    color: #22c55e;
    border-color: #22c55e;
  }

  .status-pill--in-progress {
    color: #f59e0b;
    border-color: #f59e0b;
  }
</style>
