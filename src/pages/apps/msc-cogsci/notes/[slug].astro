---
import { getCollection, render } from "astro:content";
import AppShell from "../../../../layouts/AppShell.astro";

export async function getStaticPaths() {
  const notes = await getCollection("vaultNotes");
  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content, headings } = await render(note);

const title =
  note.data.title ??
  headings.find((h) => h.depth === 1)?.text ??
  note.id.replace(/--/g, " — ").replace(/-/g, " ");

const typeLabel = note.data.type ?? null;
const status = note.data.status ?? null;
---

<AppShell title={title} description={`MSc notes — ${title}`} scrollable={true}>
  <div class="note-wrapper">
    <nav class="note-breadcrumb">
      <a href="/apps/msc-cogsci/">curriculum</a>
      <span aria-hidden="true">/</span>
      <a href="/apps/msc-cogsci/notes/">notes</a>
      <span aria-hidden="true">/</span>
      <span>{title}</span>
    </nav>

    <header class="note-header">
      <div class="note-meta">
        {typeLabel && <span class="note-badge note-badge--type">{typeLabel}</span>}
        {status && <span class={`note-badge note-badge--status note-badge--${status}`}>{status}</span>}
      </div>
      <h1 class="note-title">{title}</h1>
    </header>

    <div class="note-content prose">
      <Content />
    </div>
  </div>
</AppShell>

<style>
  .note-wrapper {
    max-width: 72ch;
    margin: 0 auto;
    padding: var(--space-8) var(--space-6) var(--space-16);
  }

  .note-breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
    flex-wrap: wrap;
  }

  .note-breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
    cursor: pointer;
  }

  .note-breadcrumb a:hover {
    color: var(--color-text);
    text-decoration: underline;
  }

  .note-header {
    margin-bottom: var(--space-8);
  }

  .note-meta {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
    flex-wrap: wrap;
  }

  .note-badge {
    display: inline-block;
    padding: 0.15em 0.6em;
    border-radius: 9999px;
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: lowercase;
    letter-spacing: 0.02em;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    background: var(--color-surface-2, transparent);
  }

  .note-badge--status.note-badge--done {
    color: var(--color-success, #22c55e);
    border-color: var(--color-success, #22c55e);
  }

  .note-badge--status.note-badge--in-progress {
    color: var(--color-accent, #f59e0b);
    border-color: var(--color-accent, #f59e0b);
  }

  .note-badge--status.note-badge--shipped {
    color: var(--color-primary, #6366f1);
    border-color: var(--color-primary, #6366f1);
  }

  .note-title {
    font-size: var(--text-3xl, 1.875rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-text);
    margin: 0;
  }

  /* Wikilink styles */
  .note-content :global(a.wiki-link) {
    color: var(--color-primary, #6366f1);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
    cursor: pointer;
  }

  .note-content :global(a.wiki-link:hover) {
    border-bottom-color: var(--color-primary, #6366f1);
  }

  /* Broken/missing wikilinks */
  .note-content :global(a.wiki-link.wiki-link-new) {
    color: var(--color-text-muted);
    cursor: default;
    pointer-events: none;
  }

  /* Prose content */
  .prose {
    line-height: 1.75;
    color: var(--color-text);
  }

  .prose :global(a) {
    cursor: pointer;
  }

  .prose :global(h1) { display: none; } /* title already shown above */

  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    font-weight: 600;
    margin-top: 2em;
    margin-bottom: 0.5em;
    color: var(--color-text);
  }

  .prose :global(h2) { font-size: var(--text-xl, 1.25rem); }
  .prose :global(h3) { font-size: var(--text-lg, 1.125rem); }

  .prose :global(p) {
    margin-bottom: 1em;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5em;
    margin-bottom: 1em;
  }

  .prose :global(li) {
    margin-bottom: 0.25em;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-border);
    padding-left: var(--space-4);
    color: var(--color-text-muted);
    margin: 1.5em 0;
    font-style: italic;
  }

  .prose :global(code:not(pre code)) {
    font-size: 0.875em;
    background: var(--color-surface-2, rgba(127,127,127,0.1));
    padding: 0.15em 0.35em;
    border-radius: 0.25em;
  }

  .prose :global(pre) {
    border-radius: 0.5em;
    overflow-x: auto;
    margin: 1.5em 0;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    margin: 1.5em 0;
  }

  .prose :global(th),
  .prose :global(td) {
    text-align: left;
    padding: 0.5em 0.75em;
    border: 1px solid var(--color-border);
  }

  .prose :global(th) {
    font-weight: 600;
    background: var(--color-surface-2, transparent);
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2em 0;
  }

  .prose :global(input[type="checkbox"]) {
    margin-right: 0.4em;
  }
</style>
