---
/**
 * EndOrnament - A handmade, paper-like illustration
 * placed at the end of the home page.
 * Theme: A vintage, Da Vinci-style graphite portrait of the author.
 *
 * Uses two dedicated assets:
 *   - fpl0-sketch.png: dark graphite on cream paper (light mode)
 *   - fpl0-sketch-dark.png: cream chalk on black paper (dark mode)
 * Wrapper divs handle show/hide since Astro <Image> may generate <picture> elements.
 */
import { Image } from "astro:assets";
import authorSketch from "../assets/fpl0-sketch.png";
import authorSketchDark from "../assets/fpl0-sketch-dark.png";
---

<div class="end-ornament" aria-hidden="true">
  <div class="show-light">
    <Image
      src={authorSketch}
      alt="Vintage graphite sketch of the author"
      class="ornament-image"
      width={512}
    />
  </div>
  <div class="show-dark">
    <Image
      src={authorSketchDark}
      alt="Vintage graphite sketch of the author"
      class="ornament-image"
      width={512}
    />
  </div>
</div>

<style>
  .end-ornament {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-top: var(--space-y-xl);
    padding: var(--space-8) 0;
    width: 100%;
  }

  .ornament-image {
    height: calc(var(--font-size-h2) * 6.5);
    width: auto;
    object-fit: contain;
    transition:
      filter var(--duration-slow) var(--ease-out),
      opacity var(--duration-slow) var(--ease-out);
  }

  /* Light mode: show light sketch, hide dark */
  .show-light .ornament-image {
    mix-blend-mode: multiply;
    filter: contrast(1.5) grayscale(1) sepia(0.2) opacity(0.75);
  }

  .show-dark {
    display: none;
  }

  /* Dark mode: show dark sketch, hide light */
  :global([data-theme="dark"]) .show-light {
    display: none;
  }

  :global([data-theme="dark"]) .show-dark {
    display: block;
  }

  :global([data-theme="dark"]) .show-dark .ornament-image {
    mix-blend-mode: screen;
    filter: sepia(0.08) opacity(0.85);
  }

  @media (max-width: 600px) {
    .end-ornament {
      margin-top: var(--space-y-md);
      padding: var(--space-4) 0;
    }

    .ornament-image {
      height: calc(var(--font-size-h2) * 3.5);
    }
  }
</style>
