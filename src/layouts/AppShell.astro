---
/**
 * AppShell - Minimal standalone layout for apps.
 *
 * Two modes:
 * - Default (full-viewport): fixed body, no scroll — for canvases / spatial tools.
 * - scrollable: long-form document mode — for apps that are primarily content
 *   with light interactivity (progress trackers, dashboards, reference docs).
 *
 * Both modes share the same thin top bar (back link, title, search, theme toggle)
 * and the BaseHead (theme init, fonts, meta, View Transitions).
 *
 * No ScrollToTop or Analytics — apps are standalone.
 */

import "../styles/global.css";
import "../styles/app-shell.css";

import BaseHead from "../components/BaseHead.astro";
import Link from "../components/Link.astro";
import SearchModal from "../components/SearchModal.astro";
import ThemeToggle from "../components/ThemeToggle.astro";

interface Props {
  title: string;
  description?: string;
  scrollable?: boolean;
}

const {
  title,
  description = "An interactive app on fpl0's blog.",
  scrollable = false,
} = Astro.props;

const bodyClass = scrollable ? "app-shell-body app-shell-body--scrollable" : "app-shell-body";
const contentClass = scrollable
  ? "app-shell-content app-shell-content--scrollable"
  : "app-shell-content";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead {title} {description} />
	</head>
	<body class={bodyClass}>
		<a href="#main-content" class="skip-link">Skip to content</a>
		<header class="app-shell-bar">
			<nav class="app-shell-nav" aria-label="App navigation">
				<Link href="/" class="app-shell-link"><span class="app-shell-back" aria-hidden="true">&larr;</span> fpl0</Link>
			</nav>
			<Link href="/" class="app-shell-title">
				<span class="app-shell-title-back" aria-hidden="true">&larr;</span>
				{title}
			</Link>
			<div class="app-shell-right">
				<button
					class="app-shell-search"
					id="app-shell-search"
					type="button"
					aria-label="Search"
					aria-controls="search-backdrop"
				>
					<svg class="app-shell-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<circle cx="11" cy="11" r="8"></circle>
						<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
					</svg>
					<span class="app-shell-search-text">search</span>
					<kbd class="app-shell-search-kbd kbd-mac">⌘K</kbd>
				<kbd class="app-shell-search-kbd kbd-other">Ctrl+K</kbd>
				</button>
				<ThemeToggle />
			</div>
		</header>
		<SearchModal />
		<main class={contentClass} id="main-content">
			<slot />
		</main>
	</body>
</html>

<style>
	/* Override blog body constraints — full-viewport apps fix the body */
	.app-shell-body {
		max-width: none;
		margin: 0;
		padding: 0;
		overflow: hidden;
		height: 100vh;
	}

	/* Document mode — long-form content that scrolls naturally.
	   Keeps the fixed app bar but lets the body flow past the viewport. */
	.app-shell-body--scrollable {
		max-width: none;
		margin: 0;
		padding: 0;
		overflow: visible;
		height: auto;
		min-height: 100vh;
	}

	/* Size theme toggle to match app-shell bar */
	.app-shell-right :global(.theme-toggle) {
		width: var(--space-8);
		height: var(--space-8);
	}

	.app-shell-right :global(.theme-toggle .icon) {
		width: var(--space-4);
		height: var(--space-4);
	}

</style>
