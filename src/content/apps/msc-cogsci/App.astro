---
/**
 * msc — My Self-Directed MSc in Cognitive Science
 *
 * A public programme report, not a dashboard. Source of truth:
 * `completedWeeks` + `inProgressWeek` in src/data/msc-curriculum.ts. Fully
 * server-rendered, no client-side state except a small hash-to-details
 * promoter for deep-links.
 */

import Link from "../../../components/Link.astro";
import Fleuron from "../../../components/Fleuron.astro";
import {
  inProgressWeek,
  type ItemKind,
  programme,
  semesters,
  type WeekItem,
} from "../../../data/msc-curriculum";
import {
  awaitsLink,
  buildSemesterTicks,
  getProgressSnapshot,
  isWeekDone,
  moduleForWeek,
  pad2,
  RAIL_SUFFIX,
  railState,
  TICK_SUFFIX,
  weekById,
} from "../../../utils/msc-progress";
import "../../../styles/msc.css";
import DETAILS_SCRIPT from "../../../components/msc-details.inline.js?raw";

const kindLabel: Record<ItemKind, string> = {
  read: "Read",
  watch: "Watch",
  paper: "Paper",
  code: "Code",
  write: "Write",
  activity: "Do",
  note: "Note",
};

const semesterSlug = (n: number) => `semester-${n}`;
const weekSlug = (n: number) => `week-${n}`;

const { weeksDone, artifactsDone, percentComplete } = getProgressSnapshot();
const semesterTicks = buildSemesterTicks();

const todayIso = new Date().toISOString().slice(0, 10);

const ROMAN: Record<number, string> = { 1: "I", 2: "II", 3: "III", 4: "IV", 5: "V" };

const currentWeek = inProgressWeek !== null ? weekById(inProgressWeek) : undefined;
const currentContext = inProgressWeek !== null ? moduleForWeek(inProgressWeek) : null;
const currentSemesterLabel = currentContext ? (ROMAN[currentContext.semester.n] ?? "") : "";

function currentlySentence(): string | null {
  if (!(currentWeek && currentContext)) return null;
  const mod = currentContext.module.title.replace(/[.!?]+$/, "");
  const artifactLine = currentWeek.artifact
    ? ` A ${currentWeek.artifact.kind.toLowerCase()} ships this week.`
    : "";
  return `In Week ${currentWeek.n} — ${currentWeek.title} — reading ${mod}.${artifactLine}`;
}

const currently = currentlySentence();
---

<div class="msc-main">
  <!-- ============================================================== HERO -->
  <header class="msc-hero">
    <h1 class="msc-title">
      My Self-Directed MSc in<br />
      <span class="msc-title-accent">Cognitive Science</span>
    </h1>
    <p class="msc-tagline">{programme.tagline}</p>
    <p class="msc-hero-caption">
      Curriculum synthesised from MIT, CMU, Stanford, Edinburgh, UCSD, Indiana, and Sussex — in
      the tradition of
      <Link
        href="https://www.scotthyoung.com/blog/myprojects/mit-challenge-2/"
        class="msc-hero-lineage"
      >Scott H. Young's MIT Challenge</Link>.
    </p>
    <p class="msc-hero-meta">
      Started {programme.startedLabel} · {programme.totalWeeks} weeks ·
      {programme.totalSemesters} semesters · {programme.totalArtifacts} artifacts ·
      {programme.pace}.
    </p>
  </header>

  <!-- ============================================================== STATE -->
  <section class="msc-state" aria-labelledby="state-heading">
    <h2 id="state-heading" class="msc-section-title">The state of the work</h2>

    <p class="msc-state-dateline">
      As of <time datetime={todayIso}>{todayIso}</time> ·
      {weeksDone} of {programme.totalWeeks} weeks · {percentComplete}% · {artifactsDone} of
      {programme.totalArtifacts} artifacts shipped
      {currentContext && (
        <>
          · Semester {currentSemesterLabel}
        </>
      )}
    </p>

    <!-- Progress strip — 80 weeks, 5 semester groups -->
    <div
      class="msc-strip msc-strip--weeks"
      role="img"
      aria-label={`${weeksDone} of ${programme.totalWeeks} weeks complete`}
    >
      {semesterTicks.map((s) => (
        <div class="msc-strip-group" style={`flex: ${s.count} 0 0`}>
          {s.weeks.map((w) => {
            const wk = weekById(w.n);
            const ctx = moduleForWeek(w.n);
            const suffix = TICK_SUFFIX[w.state];
            const parts = [`W${pad2(w.n)}`];
            if (wk?.title) parts.push(wk.title);
            if (ctx) parts.push(`S${ctx.semester.n} · ${ctx.module.code}`);
            const tooltip = parts.join(" · ") + suffix;
            return (
              <a
                href={`#${weekSlug(w.n)}`}
                class={`msc-strip-tick msc-strip-tick--${w.state}`}
                aria-label={`Week ${w.n}${suffix}`}
                data-tooltip={tooltip}
              />
            );
          })}
        </div>
      ))}
    </div>

    <!-- Artifact rail — 80-axis, but only the 21 artifact weeks carry weight -->
    <div class="msc-rail" role="img" aria-label={`${artifactsDone} of ${programme.totalArtifacts} artifacts shipped`}>
      {semesterTicks.map((s) => (
        <div class="msc-rail-group" style={`flex: ${s.count} 0 0`}>
          {s.weeks.map((w) => {
            const state = railState(w.n);
            if (state === null) {
              return <span class="msc-rail-tick msc-rail-tick--empty" aria-hidden="true" />;
            }
            const art = weekById(w.n)?.artifact;
            const suffix = RAIL_SUFFIX[state];
            const parts = [`W${pad2(w.n)}`];
            if (art?.title) parts.push(art.title);
            if (art) parts.push(`${art.kind} · ${art.length}`);
            const tooltip = parts.join(" · ") + suffix;
            const showDiamond = state === "shipped" || state === "current";
            return (
              <a
                href={`#${weekSlug(w.n)}`}
                class={`msc-rail-tick msc-rail-tick--${state}`}
                aria-label={`Artifact, week ${w.n}${suffix}`}
                data-tooltip={tooltip}
              >
                {showDiamond && <Fleuron variant="diamond" filled />}
                {state === "next" && <span class="msc-rail-tick-dot" aria-hidden="true" />}
              </a>
            );
          })}
        </div>
      ))}
    </div>

    {currently && (
      <p class="msc-state-currently">
        <span class="msc-state-currently-label">Currently</span>
        <span class="msc-state-currently-body">
          {currently}
          {currentWeek && (
            <>
              {" "}
              <a class="msc-state-currently-link" href={`#${weekSlug(currentWeek.n)}`}>
                Open Week {currentWeek.n} →
              </a>
            </>
          )}
        </span>
      </p>
    )}
  </section>

  <!-- ============================================================== CURRICULUM -->
  <section class="msc-curriculum" aria-labelledby="curriculum-heading">
    <h2 id="curriculum-heading" class="msc-section-title">The curriculum</h2>
    <p class="msc-curriculum-sub">
      Five semesters, {programme.totalModules} modules, {programme.totalArtifacts} shippable
      artifacts. Click a semester to expand, or jump straight to a week via the progress bar above.
    </p>

    {semesters.map((s) => {
      const semWeeks = Array.from(
        { length: s.weeks[1] - s.weeks[0] + 1 },
        (_, i) => s.weeks[0] + i,
      );
      const doneCount = semWeeks.filter(isWeekDone).length;
      return (
        <details class="msc-semester" id={semesterSlug(s.n)}>
          <summary class="msc-semester-summary">
            <span class="msc-semester-kicker">
              Semester {ROMAN[s.n] ?? s.n} · Weeks {s.weeks[0]}–{s.weeks[1]}
            </span>
            <span class="msc-semester-title">{s.title}</span>
            <span class="msc-semester-progress" aria-label={`${doneCount} of ${semWeeks.length} weeks done`}>
              <span class="msc-semester-progress-count">
                {doneCount} / {semWeeks.length}
              </span>
              <span class="msc-semester-progress-bar" aria-hidden="true">
                <span
                  class="msc-semester-progress-fill"
                  style={`--fill: ${(doneCount / semWeeks.length) * 100}%`}
                />
              </span>
            </span>
          </summary>

          <p class="msc-semester-subtitle">{s.subtitle}</p>

          {s.modules.map((m) => (
            <section class="msc-module">
              <header class="msc-module-header">
                <p class="msc-module-kicker">
                  Module {m.code} · Weeks {m.weeks[0]}–{m.weeks[1]}
                </p>
                <h3 class="msc-module-title">{m.title}</h3>
                <p class="msc-module-question">{m.question}</p>
              </header>

              <ol class="msc-weeks">
                {m.weekDetails.map((wk) => {
                  const isDone = isWeekDone(wk.n);
                  const isPending = awaitsLink(wk.n);
                  const isActive = wk.n === inProgressWeek;
                  const cls = [
                    "msc-week",
                    isDone ? "is-done" : "",
                    isPending ? "is-awaiting-link" : "",
                    isActive ? "is-in-progress" : "",
                  ]
                    .filter(Boolean)
                    .join(" ");
                  return (
                    <li class={cls} id={weekSlug(wk.n)}>
                      <div class="msc-week-row">
                        <span class="msc-week-check-box" aria-hidden="true">
                          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 8l3.5 3.5L13 5"></path>
                          </svg>
                        </span>
                        <span class="msc-week-meta">
                          <span class="msc-week-num">W{pad2(wk.n)}</span>
                          {wk.hours && <span class="msc-week-hours">{wk.hours} hrs</span>}
                        </span>
                        <span class="msc-week-title">{wk.title}</span>
                      </div>

                      {wk.items.length > 0 && (
                        <ul class="msc-week-items">
                          {wk.items.map((it: WeekItem) => (
                            <li class={`msc-week-item msc-kind-${it.kind}`}>
                              <span class="msc-kind-tag">{kindLabel[it.kind]}</span>
                              <span class="msc-kind-text">{it.text}</span>
                            </li>
                          ))}
                        </ul>
                      )}

                      {wk.artifact && (
                        <div class="msc-artifact">
                          <span class="msc-artifact-flag">
                            <Fleuron variant="diamond" filled={!!wk.artifact.link} />
                            {wk.artifact.link ? "Artifact shipped" : "Artifact due"}
                          </span>
                          <div class="msc-artifact-body">
                            <p class="msc-artifact-title">{wk.artifact.title}</p>
                            <p class="msc-artifact-meta">
                              {wk.artifact.kind} · {wk.artifact.length}
                            </p>
                            {wk.artifact.description && (
                              <p class="msc-artifact-description">{wk.artifact.description}</p>
                            )}
                            {wk.artifact.link ? (
                              <p class="msc-artifact-link">
                                <Link href={wk.artifact.link}>View published artifact →</Link>
                              </p>
                            ) : (
                              isPending && (
                                <p class="msc-artifact-pending">
                                  Work done · awaiting published link before this week counts as complete.
                                </p>
                              )
                            )}
                          </div>
                        </div>
                      )}
                    </li>
                  );
                })}
              </ol>
            </section>
          ))}
        </details>
      );
    })}
  </section>

  <!-- ============================================================== METHOD -->
  <section class="msc-method" aria-labelledby="method-heading">
    <h2 id="method-heading" class="msc-section-title">How this works</h2>

    <div class="msc-method-rows">
      {programme.methodology.map((item) => (
        <div class="msc-method-row">
          <h3 class="msc-method-row-title">{item.heading}</h3>
          <p class="msc-method-row-body">{item.body}</p>
        </div>
      ))}
    </div>

    <div class="msc-budget">
      <div class="msc-budget-header">
        <h3 class="msc-budget-title">Weekly time budget</h3>
        <p class="msc-budget-total">
          <span class="msc-budget-total-value">{programme.pace}</span>
        </p>
      </div>
      <div class="msc-budget-rows">
        {programme.weeklyBudget.map((b) => (
          <div class="msc-budget-row">
            <span class="msc-budget-activity">{b.activity}</span>
            <span class="msc-budget-hours">{b.hours}</span>
            <span class="msc-budget-note">{b.note}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================== COLOPHON -->
  <footer class="msc-colophon">
    <p class="msc-colophon-meta">
      {programme.totalWeeks} weeks · {programme.totalArtifacts} artifacts · 25+ canonical
      textbooks · 60+ foundational papers.
    </p>
  </footer>

  <script is:inline set:html={DETAILS_SCRIPT} />
</div>
